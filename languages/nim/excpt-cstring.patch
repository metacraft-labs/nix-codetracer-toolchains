+  proc addCstringToString(s: var string, cs: cstring) =
+    # add(var string, cstring) is defined later in system.nim, so it is not
+    # available here yet.  Inline the same char-by-char loop.
+    var i = 0
+    if cs != nil:
+      while cs[i] != '\0':
+        add(s, cs[i])
+        inc(i)
