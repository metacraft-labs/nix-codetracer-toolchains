             for k in 1..max(1, 25-(s.len-oldLen)): add(s, ' ')
-            add(s, tempDlInfo.dli_sname)
+            addCstringToString(s, tempDlInfo.dli_sname)
         else:
           add(s, '?')
         add(s, "\n")
